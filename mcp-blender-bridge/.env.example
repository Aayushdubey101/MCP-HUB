# MCP-Blender-Bridge — environment variables
# Copy to `.env` and adjust. None are required; all have sane defaults.

# --- Connection to the Blender addon ---
BLENDER_BRIDGE_HOST=127.0.0.1
BLENDER_BRIDGE_PORT=9876

# --- Logging ---
# Level: DEBUG | INFO | WARNING | ERROR
BLENDER_BRIDGE_LOG_LEVEL=INFO
# Format: text | json   (json = one JSON object per line, ready for log infra)
BLENDER_BRIDGE_LOG_FORMAT=text

# --- Safety ---
# When true, every destructive tool refuses to run.
# Read tools (ping, scene_info, list_objects, get_object_info, viewport_screenshot)
# still work. Useful for shared / demo / regulated instances.
BLENDER_BRIDGE_READ_ONLY=false

# --- Performance ---
# When true, the server keeps a single TCP connection open to the Blender addon
# and reuses it across all tool calls (saves the per-call handshake). Reconnects
# automatically on broken pipe. Default false for the simplest, most robust mode.
BLENDER_BRIDGE_PERSISTENT=false

# --- Future / plugin env vars (do not set unless plugin installed) ---
# HYPER3D_API_KEY=
# SKETCHFAB_API_KEY=
# POLYHAVEN_CACHE_DIR=
