# MCP-Blender-Bridge — environment variables
# Copy to `.env` and adjust. None are required; all have sane defaults.
# Plugin-specific vars (HYPER3D_API_KEY, etc.) are only needed when that
# plugin is installed and you want to use its API-dependent tools.

# ─── Core: Connection to the Blender addon ────────────────────────────────────
BLENDER_BRIDGE_HOST=127.0.0.1
BLENDER_BRIDGE_PORT=9876

# ─── Core: Logging ────────────────────────────────────────────────────────────
# Level: DEBUG | INFO | WARNING | ERROR
BLENDER_BRIDGE_LOG_LEVEL=INFO
# Format: text | json   (json = one JSON object per line, ready for log infra)
BLENDER_BRIDGE_LOG_FORMAT=text

# ─── Core: Safety ─────────────────────────────────────────────────────────────
# When true, every destructive tool refuses to run.
# Read tools (ping, scene_info, list_objects, get_object_info, viewport_screenshot)
# still work. Useful for shared / demo / regulated instances.
BLENDER_BRIDGE_READ_ONLY=false

# ─── Core: Performance ────────────────────────────────────────────────────────
# When true, the server keeps a single TCP connection open to the Blender addon
# and reuses it across all tool calls (saves the per-call handshake). Reconnects
# automatically on broken pipe. Default false for the simplest, most robust mode.
BLENDER_BRIDGE_PERSISTENT=false

# ─── Core: HTTP transport (only used with --transport http) ───────────────────
# Required when running `mcp-blender-bridge --transport http`.
# The server will refuse to start in HTTP mode without this.
# BLENDER_BRIDGE_AUTH_TOKEN=change-me-to-something-random

# ─── Core: Asset cache ────────────────────────────────────────────────────────
# Shared cache directory for all plugins (PolyHaven, Hyper3D, Sketchfab).
# Defaults to ~/.cache/mcp-blender-bridge/assets/
# BLENDER_BRIDGE_CACHE_DIR=~/.cache/mcp-blender-bridge/assets

# ─── Plugin: mcp-blender-bridge-polyhaven ─────────────────────────────────────
# No API key required! PolyHaven is free and open.
# Override the cache directory for PolyHaven assets specifically.
# POLYHAVEN_CACHE_DIR=~/.cache/mcp-blender-bridge/assets/polyhaven

# ─── Plugin: mcp-blender-bridge-hyper3d ───────────────────────────────────────
# Get your API key at https://hyper3d.ai (BYO — never embedded in this package).
# HYPER3D_API_KEY=your-key-here

# ─── Plugin: mcp-blender-bridge-sketchfab ─────────────────────────────────────
# Get your API token at https://sketchfab.com/settings#password
# Required only for downloads (search works without a key).
# SKETCHFAB_API_KEY=your-token-here
